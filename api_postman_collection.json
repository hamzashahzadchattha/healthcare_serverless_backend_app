          "response": []
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"confirmation_code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "verify"
              ]
            },
            "description": "Confirm signup with the OTP sent by Cognito."
          },
          "response": []
        },
        {
          "name": "Signin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
