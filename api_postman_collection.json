              "raw": "{{base_url}}/auth/signin",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "signin"
              ]
            },
            "description": "Authenticate with email/password and return Cognito tokens."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
