# Copy this to .env.dev (for dev stage) or .env.prod and fill in the values.
# These are NON-SECRET configuration values only — all secrets go in AWS Secrets Manager.

STAGE=dev
REGION=us-east-1
LOG_LEVEL=DEBUG

# Cognito Social Identity Providers
# Google OAuth 2.0 credentials — obtain from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Sign in with Apple credentials — obtain from https://developer.apple.com/
APPLE_SERVICES_ID=com.example.your-services-id
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_APPLE_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"