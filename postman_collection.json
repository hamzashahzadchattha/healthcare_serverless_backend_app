{
    "info": {
        "name": "Healthcare Assesment API",
        "description": "Postman Collection for the Healthcare Assesment Serverless API.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Patients",
            "item": [
                {
                    "name": "Register Patient",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"date_of_birth\": \"1990-01-01\",\n  \"email\": \"john.doe@example.com\",\n  \"phone_number\": \"+15551234567\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/patients/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "patients",
                                "register"
                            ]
                        },
                        "description": "Register a new patient. like email, phone, and DOB are securely hashed on the backend."
                    },
                    "response": []
                },
                {
                    "name": "Get Upcoming Appointments",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/patients/{{patient_id}}/appointments/upcoming?page=1&limit=50",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "patients",
                                "{{patient_id}}",
                                "appointments",
                                "upcoming"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1",
                                    "description": "Page number (1-indexed)"
                                },
                                {
                                    "key": "limit",
                                    "value": "50",
                                    "description": "Items per page"
                                }
                            ]
                        },
                        "description": "List all future scheduled appointments for a patient. Paginated."
                    },
                    "response": []
                },
                {
                    "name": "Get Prescriptions",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/patients/{{patient_id}}/prescriptions?filter=active&page=1&limit=50",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "patients",
                                "{{patient_id}}",
                                "prescriptions"
                            ],
                            "query": [
                                {
                                    "key": "filter",
                                    "value": "active",
                                    "description": "Filter by status: active, past, or all"
                                },
                                {
                                    "key": "page",
                                    "value": "1",
                                    "description": "Page number (1-indexed)"
                                },
                                {
                                    "key": "limit",
                                    "value": "50",
                                    "description": "Items per page"
                                }
                            ]
                        },
                        "description": "List all prescriptions for a patient. Supports filtering and pagination."
                    },
                    "response": []
                },
                {
                    "name": "Get Education Videos",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/patients/{{patient_id}}/education-videos",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "patients",
                                "{{patient_id}}",
                                "education-videos"
                            ]
                        },
                        "description": "Fetch recommended YouTube education videos based on patient's active/chronic medical conditions."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Appointments",
            "item": [
                {
                    "name": "Upload Provider Notes",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"note_text\": \"Patient presented with mild hypertension. Recommended dietary changes and follow-up in 3 months.\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/appointments/{{appointment_id}}/notes",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "appointments",
                                "{{appointment_id}}",
                                "notes"
                            ]
                        },
                        "description": "Upload a clinical note for a specific appointment. Uses dummy provider ID on the backend since Cognito auth is removed."
                    },
                    "response": []
                }
            ]
        }
    ],
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [
                    ""
                ]
            }
        },
        {
            "listen": "test",
            "script": {
                "type": "text/javascript",
                "exec": [
                    ""
                ]
            }
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "https://2e5jocfs9d.execute-api.us-east-1.amazonaws.com",
            "type": "string"
        },
        {
            "key": "patient_id",
            "value": "b2c3d4e5-0001-4000-8000-000000000001",
            "type": "string",
            "description": "already seeded patient"
        },
        {
            "key": "appointment_id",
            "value": "c3d4e5f6-0001-4000-8000-000000000001",
            "type": "string",
            "description": "already seeded appointment"
        }
    ]
}